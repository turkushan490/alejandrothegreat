# Everything the bot needs to run (Discord bot token, Spotify credentials,
# admin password) is configured through the web setup wizard at /setup.html
# once the container is running - you don't need to fill in a .env file.
#
# These are only used to pre-fill the setup wizard's fields, and only
# matter the very first time you open it. Leave them all blank if you'd
# rather just type everything into the wizard directly.

# DISCORD_BOT_TOKEN=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_REDIRECT_URI=http://192.168.1.100:3000/auth/discord/callback
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# Infra-level settings (actually required, but the defaults below work for most setups)
PORT=3000
DATA_DIR=./data
