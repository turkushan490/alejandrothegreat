# Discord Developer Portal -> your application
# https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Must exactly match a redirect configured in the Discord app's OAuth2 settings.
# For local Unraid access this is your server's LAN IP and the port below.
DISCORD_REDIRECT_URI=http://192.168.1.100:3000/auth/discord/callback

# Spotify Developer Dashboard -> your app (used for search/playlist metadata only)
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Random long string used to sign session cookies. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Port the web dashboard listens on inside the container
PORT=3000

# Where the SQLite database file is stored (mount this as a Docker volume)
DATA_DIR=./data
